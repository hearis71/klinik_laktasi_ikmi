{
    "name": "klinik-laktasi/klinik-laktasi2",
    "description": "Sistem Manajemen Klinik Laktasi",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "config/config.php",
            "config/database.php",
            "includes/auth.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "@php setup-database.php"
        ]
    }
}
